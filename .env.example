# Copy to .env and fill in real values. Never commit .env.
# SECRET_KEY must be >= 32 random bytes (e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`).
POSTGRES_USER=eowe
POSTGRES_PASSWORD=change-me
POSTGRES_DB=eowe
# Host is "db" inside docker compose; use "localhost" when running alembic/uvicorn on the host.
DATABASE_URL=postgresql+psycopg2://eowe:change-me@db:5432/eowe
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
ENVIRONMENT=development
